# ============================================================
# CloudBase CloudRun 部署环境变量示例
#
# 使用方式:
#   1. 在 CloudBase 控制台或通过 tcb secrets set 配置以下变量
#   2. 复制本文件为 .env.cloudbase,填入实际值
#   3. 部署时通过 cloudbaserc.json 或 tcb 命令注入
# ============================================================

# ---------- CloudBase 环境 ----------
# CloudBase 环境 ID (在控制台创建环境后获取)
TCB_ENV_ID=your-env-id

# ---------- 后端服务 (nebula-server) ----------
# 数据库: 推荐使用 CloudBase PostgreSQL
# 在控制台 "数据库 > PostgreSQL" 创建后获取连接串
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://username:password@pgm-xxx.sql.tencentcloudbase.com:5432/nestdb?schema=public

# Redis: 使用 CloudBase Redis 或外部 Redis 服务
REDIS_HOST=redis-xxx.c.tencentcloudbase.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_KEY_PREFIX=nebula:

# JWT 密钥(必须修改,长度至少 32 字符)
# 生成方式: openssl rand -base64 48
JWT_SECRET=change-this-to-a-secure-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-this-to-a-secure-refresh-secret-at-least-32-chars
JWT_REFRESH_TTL=7d

# 应用配置
API_PREFIX=api
# CORS 来源: 前端 CloudRun 服务的公网地址,多个用逗号分隔
CORS_ORIGIN=https://nebula-web-xxx.tcloudbaseapp.com
# 生产环境建议关闭 Swagger
ENABLE_SWAGGER=false
# 文件上传(CloudRun 无状态,使用 /tmp 临时目录,持久化请用云存储)
FILE_UPLOAD_DIR=/tmp/uploads
FILE_MAX_SIZE=10485760

# ---------- 前端服务 (nebula-web) ----------
# 后端 CloudRun 服务的公网地址
# 部署后端后,从 CloudBase 控制台获取公网访问地址
BACKEND_URL=https://nebula-server-xxx.tcloudbaseapp.com
