{
  "name": "@nebula/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types/api.types.d.mts",
        "default": "./dist/types/api.types.mjs"
      }
    },
    "./schemas": {
      "import": {
        "types": "./dist/schemas/index.d.mts",
        "default": "./dist/schemas/index.mjs"
      }
    },
    "./errors": {
      "import": {
        "types": "./dist/errors/index.d.mts",
        "default": "./dist/errors/index.mjs"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/utils/index.d.mts",
        "default": "./dist/utils/index.mjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nebula/typescript-config": "workspace:*",
    "tsx": "^4.19.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
