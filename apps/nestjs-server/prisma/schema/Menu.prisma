enum MenuType {
  menu
  button
  link
}

model Menu {
  id          String      @id @default(uuid())
  parentId    String?
  parent      Menu?       @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Menu[]      @relation("MenuHierarchy")
  name        String      @unique
  title       String
  path        String?
  icon        String?
  type        MenuType    @default(menu)
  sort        Int         @default(0)
  isActive    Boolean     @default(true)
  permission  String?
  component   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  roles       Role[]      @relation("RoleMenus")

  @@index([parentId])
  @@map("menus")
}
