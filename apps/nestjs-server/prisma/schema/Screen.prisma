model ScreenProject {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  canvas      String   @default("{}")
  components  String   @default("[]")
  /// 事件蓝图 JSON 字符串（可选；未编辑蓝图的旧项目为 null）
  blueprint   String?
  status      String   @default("draft")
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@map("screen_projects")
}
