model User {
  id            String         @id @default(uuid())
  email         String         @unique
  username      String         @unique
  password      String
  name          String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  roles         Role[]         @relation("UserRoles")

  @@map("users")
}
