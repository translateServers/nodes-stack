model DictType {
  id          String      @id @default(uuid())
  code        String      @unique
  name        String
  description String?
  isActive    Boolean     @default(true)
  sort        Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  values      DictValue[] @relation("DictTypeValues")

  @@index([code])
  @@map("dict_types")
}

model DictValue {
  id          String   @id @default(uuid())
  dictTypeId  String
  dictType    DictType @relation("DictTypeValues", fields: [dictTypeId], references: [id], onDelete: Cascade)
  code        String
  label       String
  value       String
  color       String?
  sort        Int      @default(0)
  isActive    Boolean  @default(true)
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([dictTypeId, code])
  @@index([dictTypeId])
  @@map("dict_values")
}
