model Role {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  users       User[]      @relation("UserRoles")
  menus       Menu[]      @relation("RoleMenus")

  @@map("roles")
}
