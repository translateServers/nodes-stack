# ============================================================
# Nebula 容器化部署环境变量示例
#
# 使用方式:
#   cp .env.docker.example .env
#   # 修改敏感字段(JWT_SECRET、JWT_REFRESH_SECRET、POSTGRES_PASSWORD 等)
#   docker compose up -d --build
# ============================================================

# ---------- 端口映射(宿主机:容器) ----------
# 前端访问入口
WEB_PORT=8080
# 后端 API
SERVER_PORT=3000
# PostgreSQL(生产建议移除端口暴露)
POSTGRES_PORT=5432
# Redis(生产建议移除端口暴露)
REDIS_PORT=6379

# ---------- PostgreSQL ----------
POSTGRES_USER=postgres
# 生产部署必须修改为强密码
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_DB=nestdb

# ---------- Redis ----------
REDIS_DB=0
REDIS_KEY_PREFIX=nebula:

# ---------- JWT(必须修改,长度至少 32 字符) ----------
# 可用 openssl rand -base64 48 生成
JWT_SECRET=change-this-to-a-secure-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-this-to-a-secure-refresh-secret-at-least-32-chars
JWT_REFRESH_TTL=7d

# ---------- 应用配置 ----------
API_PREFIX=api
# 前端访问地址,多个用逗号分隔(如 https://nebula.example.com)
CORS_ORIGIN=*
# 生产环境建议关闭 Swagger
ENABLE_SWAGGER=false
# 文件上传大小上限(字节,默认 10MB)
FILE_MAX_SIZE=10485760
