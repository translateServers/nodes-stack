{
  "name": "nebula-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@nebula/web",
    "dev:server": "turbo run dev --filter=@nebula/nestjs-server",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "pnpm biome:fix",
    "biome:check": "biome check .",
    "biome:fix": "biome check --write .",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "lint-staged": "^17.0.8",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.3.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": "biome check --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "packageManager": "pnpm@9.15.0"
}
